<material>
	<submaterial name="matb">
		<materialdef name="opaque_lit_doublesided"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_basecolor"></texture>
			<texture name="Normals" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_normals"></texture>
			<texture name="Masks" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_masks"></texture>
			<texture name="Masks2" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_masks2"></texture>
			<int name="Metallic Swatch" override="1"></int>
		</parameters>
		<permutations variant="0">
			<permutation>ALPHA_CUT_OUT</permutation>
		</permutations>
	</submaterial>
	<submaterial name="mata">
		<materialdef name="opaque_lit"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_basecolor"></texture>
			<texture name="Normals" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_normals"></texture>
			<texture name="Masks" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_masks"></texture>
			<texture name="Masks2" override="aztec\units\archery\tequihua\textures\tequihua_iron_mata_masks2"></texture>
			<int name="Metallic Swatch" override="1"></int>
		</parameters>
	</submaterial>
	<submaterial name="matc">
		<materialdef name="opaque_lit"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\archery\tequihua\textures\tequihua_iron_matc_basecolor"></texture>
			<texture name="Normals" override="aztec\units\archery\tequihua\textures\tequihua_iron_matc_normals"></texture>
			<texture name="Masks" override="aztec\units\archery\tequihua\textures\tequihua_iron_matc_masks"></texture>
			<texture name="Masks2" override="aztec\units\archery\tequihua\textures\tequihua_iron_matc_masks2"></texture>
			<texture name="Blood Texture" override="bloodpack\vfx\decal\overlay\textures\blood_overlay_small_01_grey_basecolor"></texture>
			<int name="Metallic Swatch" override="1"></int>
		</parameters>
	</submaterial>
</material>

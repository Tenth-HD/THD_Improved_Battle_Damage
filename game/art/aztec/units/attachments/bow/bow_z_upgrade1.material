<material>
	<submaterial name="matA">
		<materialdef name="opaque_lit_doublesided"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\attachments\bow\textures\bow_z_upgrade1_mata_basecolor"></texture>
			<texture name="Normals" override="aztec\units\attachments\bow\textures\bow_z_upgrade1_mata_normals"></texture>
			<texture name="Masks" override="aztec\units\attachments\bow\textures\bow_z_upgrade1_mata_masks"></texture>
			<texture name="Masks2" override="aztec\units\attachments\bow\textures\bow_z_upgrade1_mata_masks2"></texture>
			<texture name="Blood Texture" override="bloodpack\vfx\decal\overlay\textures\blood_overlay_small_01_grey_basecolor"></texture>
			<float name="Cloth Anim Speed" override="4.8050"></float>
			<float name="Cloth Anim Freqeuency Y" override="10.0000"></float>
			<float name="Cloth Anim Freqeuency" override="10.0000"></float>
			<float name="Cloth Anim Top Inensity" override="0.0050"></float>
			<float name="Cloth Anim Side Inensity" override="0.0120"></float>
			<int name="Cloth Can Be Damaged" override="0"></int>
			<float name="Player Color Threshold" override="0.0100"></float>
		</parameters>
		<permutations variant="0">
			<permutation>ALPHA_CUT_OUT</permutation>
			<permutation>CLOTH</permutation>
		</permutations>
	</submaterial>
</material>

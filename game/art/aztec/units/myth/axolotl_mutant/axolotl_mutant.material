<material>
	<submaterial name="matb">
		<materialdef name="opaque_lit_doublesided"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_basecolor"></texture>
			<texture name="Normals" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_normals"></texture>
			<texture name="Masks" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_masks"></texture>
			<texture name="Masks2" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_masks2"></texture>
			<texture name="Blood Texture" override="bloodpack\vfx\decal\overlay\textures\blood_overlay_small_01_rainbow_basecolor"></texture>
		</parameters>
		<permutations variant="0">
			<permutation>ALPHA_CUT_OUT</permutation>
		</permutations>
	</submaterial>
	<submaterial name="mata">
		<materialdef name="opaque_lit"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_basecolor"></texture>
			<texture name="Normals" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_normals"></texture>
			<texture name="Masks" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_masks"></texture>
			<texture name="Masks2" override="aztec\units\myth\axolotl_mutant\textures\axolotl_mutant_mata_masks2"></texture>
			<texture name="Blood Texture" override="bloodpack\vfx\decal\overlay\textures\blood_overlay_small_01_rainbow_basecolor"></texture>
		</parameters>
	</submaterial>
</material>

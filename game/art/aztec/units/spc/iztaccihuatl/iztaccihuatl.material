<material>
	<submaterial name="mata">
		<materialdef name="opaque_lit_doublesided"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_mata_basecolor"></texture>
			<texture name="Normals" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_mata_normals"></texture>
			<texture name="Masks" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_mata_masks"></texture>
			<texture name="Masks2" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_mata_masks2"></texture>
		</parameters>
		<permutations variant="0">
			<permutation>ALPHA_CUT_OUT</permutation>
		</permutations>
	</submaterial>
	<submaterial name="matc">
		<materialdef name="opaque_lit_doublesided"></materialdef>
		<parameters>
			<texture name="BaseColor" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_matc_basecolor"></texture>
			<texture name="Normals" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_matc_normals"></texture>
			<texture name="Masks" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_matc_masks"></texture>
			<texture name="Masks2" override="aztec\units\spc\iztaccihuatl\textures\iztaccihuatl_matc_masks2"></texture>
			<texture name="Blood Texture" override="bloodpack\vfx\decal\overlay\textures\blood_overlay_small_01_grey_basecolor"></texture>
		</parameters>
		<permutations variant="0">
			<permutation>ALPHA_CUT_OUT</permutation>
		</permutations>
	</submaterial>
</material>

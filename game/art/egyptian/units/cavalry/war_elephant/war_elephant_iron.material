<material>
	<submaterial name="matA">
		<materialdef name="opaque_lit"></materialdef>
		<parameters>
			<texture name="BaseColor" override="egyptian\units\cavalry\war_elephant\textures\war_elephant_iron_mata_basecolor"></texture>
			<texture name="Normals" override="egyptian\units\cavalry\war_elephant\textures\war_elephant_iron_mata_normals"></texture>
			<texture name="Masks" override="egyptian\units\cavalry\war_elephant\textures\war_elephant_iron_mata_masks"></texture>
			<texture name="Masks2" override="egyptian\units\cavalry\war_elephant\textures\war_elephant_iron_mata_masks2"></texture>
			<int name="Use Gradient" override="1"></int>
			<float name="Gradient Height" override="3.4000"></float>
		</parameters>
	</submaterial>
	<submaterial name="matB">
		<materialdef name="opaque_lit"></materialdef>
		<parameters>
			<texture name="BaseColor" override="egyptian\units\cavalry\war_elephant\textures\war_elephant_iron_matb_basecolor"></texture>

<material>
	<submaterial name="mata">
		<materialdef name="opaque_lit"></materialdef>
		<parameters>
			<texture name="BaseColor" override="norse\units\myth\fire_giant\textures\fire_giant_mata_basecolor"></texture>
			<texture name="Normals" override="norse\units\myth\fire_giant\textures\fire_giant_mata_normals"></texture>
			<texture name="Masks" override="norse\units\myth\fire_giant\textures\fire_giant_mata_masks"></texture>
			<texture name="Masks2" override="norse\units\myth\fire_giant\textures\fire_giant_mata_masks2"></texture>
			<texture name="Emissive Texture" override="norse\units\myth\fire_giant\textures\fire_giant_mata_emissive"></texture>
			<texture name="Emissive Crawling Texture" override="vfx\textures\emissive_crawling02_fire"></texture>
			<texture name="Blood Texture" override="bloodpack\vfx\decal\overlay\textures\blood_overlay_small_01_yellow_basecolor"></texture>
			<float name="Emissive Crawling Speed" override="0.3570"></float>
			<float name="Emissive Crawling UV Scale" override="2.8200"></float>
			<float name="Emissive Intensity" override="1.2440"></float>
			<texture name="Cloth Damage Mask" override="libraries\textures\cloth_tear"></texture>
		</parameters>
		<permutations variant="0">
			<permutation>EMISSIVE</permutation>
		</permutations>
	</submaterial>
</material>
